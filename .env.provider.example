# Copy to .env.provider and fill only what you need.

# MiniMax reviewer smoke test (recommended first)
MINIMAX_API_KEY=
MINIMAX_REGION=global
# Optional explicit override. If unset, region decides between
# https://api.minimax.io/anthropic/v1/messages
# and https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_BASE_URL=
MINIMAX_REVIEW_MODEL=MiniMax-M2.7

# OpenAI-compatible reviewer smoke test
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_REVIEW_MODEL=gpt-4.1-mini

# Anthropic-style reviewer smoke test
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_REVIEW_MODEL=claude-3-5-haiku-latest
