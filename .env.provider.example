# ~/.codex-self-evolution/.env.provider
#
# API KEYS ONLY live here (environment-variable style, one per line).
# Behavior configuration (model, base_url, timeout, provider selection)
# lives in config.toml. Run `codex-self-evolution config init` to seed one.
#
# Copy to .env.provider and fill only the row(s) for the provider you use.
# Unused rows can stay commented / empty.

# ======================================================================
# MiniMax (default, quick start)
# ======================================================================
MINIMAX_API_KEY=
MINIMAX_REGION=global            # or "cn" for China

# ======================================================================
# OpenAI-compatible providers — all share the OPENAI_API_KEY env name
# Point config.toml [reviewer] base_url at the right URL:
#
#   OpenAI (official)
#     https://api.openai.com/v1/chat/completions      gpt-4.1-mini / gpt-5 etc.
#
#   DeepSeek (cheap, capable)
#     https://api.deepseek.com/v1                     deepseek-chat
#     ~ $0.14 / $0.28 per 1M tokens (in/out) as of 2026-04
#
#   GLM (智谱)
#     https://open.bigmodel.cn/api/paas/v4            glm-4-flash
#     ~ ¥0.1 / ¥0.1 per 1M tokens
#
#   Qwen (Alibaba)
#     https://dashscope.aliyuncs.com/compatible-mode/v1   qwen-turbo
#     ~ ¥0.3 / ¥0.6 per 1M tokens
#
#   Gemini (via Google's OpenAI-compat endpoint)
#     https://generativelanguage.googleapis.com/v1beta/openai   gemini-2.5-flash
#     ~ $0.075 / $0.30 per 1M tokens
#
#   Together AI
#     https://api.together.xyz/v1                     meta-llama/Llama-3.3-70B-Instruct-Turbo
#
#   Fireworks AI
#     https://api.fireworks.ai/inference/v1           accounts/fireworks/models/...
#
# Prices change — verify with each provider's pricing page. OpenAI-compat
# listings above as of 2026-04.
# ======================================================================
OPENAI_API_KEY=

# ======================================================================
# Anthropic (official) or Anthropic-style proxies
# Point config.toml [profiles.<name>] base_url at one of:
#
#   Anthropic (official)                                 claude-3-5-haiku-latest / sonnet
#     https://api.anthropic.com/v1/messages              → reads ANTHROPIC_API_KEY by default
#
#   GLM (智谱) — Anthropic-compat                         glm-5 / glm-4.5-air
#     https://open.bigmodel.cn/api/anthropic/v1/messages → set api_key_env="ZHIPU_API_KEY"
#
#   Kimi (Moonshot) — Anthropic-compat                   kimi-k2.6
#     https://api.kimi.com/coding/v1/messages            → set api_key_env="KIMI_API_KEY"
#
# Each profile can declare its own `api_key_env` in config.toml so several
# anthropic-style providers coexist without stomping on ANTHROPIC_API_KEY.
# ======================================================================
ANTHROPIC_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=

# ======================================================================
# Subprocess providers (codex-cli / opencode-cli) — NO API KEY NEEDED
# They authenticate through the respective CLI's own login. Make sure
# the CLI is installed and logged in:
#   codex auth login                    # then set reviewer.provider="codex-cli"
#   opencode auth                       # then set reviewer.provider="opencode-cli"
# ======================================================================

# ======================================================================
# Legacy overrides (still honored for 0.5.x → 0.6.0 upgrades; put in
# config.toml instead going forward — see `config show` output's sources
# field to spot anything still pulling from these):
# ======================================================================
# MINIMAX_BASE_URL=
# MINIMAX_REVIEW_MODEL=
# OPENAI_BASE_URL=
# OPENAI_REVIEW_MODEL=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_REVIEW_MODEL=
